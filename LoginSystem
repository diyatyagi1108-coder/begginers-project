import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class LoginSystem extends JFrame implements ActionListener {

    JLabel titleLabel, userLabel, passLabel, messageLabel;
    JTextField userField;
    JPasswordField passField;
    JButton loginButton, resetButton;

    public LoginSystem() {

        setTitle("Login System");
        setSize(400, 300);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        setLayout(null);

      
        titleLabel = new JLabel("Smart Chatbot Login");
        titleLabel.setFont(new Font("Arial", Font.BOLD, 22));
        titleLabel.setBounds(80, 20, 250, 30);
        add(titleLabel);

        
        userLabel = new JLabel("Username:");
        userLabel.setBounds(50, 80, 100, 25);
        add(userLabel);

       
        userField = new JTextField();
        userField.setBounds(150, 80, 180, 25);
        add(userField);

        // Password Label
        passLabel = new JLabel("Password:");
        passLabel.setBounds(50, 120, 100, 25);
        add(passLabel);

        // Password Field
        passField = new JPasswordField();
        passField.setBounds(150, 120, 180, 25);
        add(passField);

        // Login Button
        loginButton = new JButton("Login");
        loginButton.setBounds(70, 190, 100, 35);
        loginButton.addActionListener(this);
        add(loginButton);

        // Reset Button
        resetButton = new JButton("Reset");
        resetButton.setBounds(210, 190, 100, 35);
        resetButton.addActionListener(this);
        add(resetButton);

        // Message Label
        messageLabel = new JLabel("");
        messageLabel.setBounds(100, 240, 250, 25);
        add(messageLabel);

        setVisible(true);
    }

   
    public void actionPerformed(ActionEvent e) {

        if (e.getSource() == loginButton) {

            String username = userField.getText();
            String password = String.valueOf(passField.getPassword());

          
            if (username.equals("admin") && password.equals("1234")) {

                messageLabel.setText("Login Successful!");
                messageLabel.setForeground(Color.GREEN);

                new ChatbotGUI();

                dispose();

            } else {

                messageLabel.setText("Invalid Username or Password!");
                messageLabel.setForeground(Color.RED);
            }
        }

        if (e.getSource() == resetButton) {

            userField.setText("");
            passField.setText("");
            messageLabel.setText("");
        }
    }
}
